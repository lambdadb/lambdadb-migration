# Migration test gates.
LAMBDADB_MIGRATION_RUN_QDRANT_MOCK_E2E=0
LAMBDADB_MIGRATION_RUN_QDRANT_REAL_E2E=0
LAMBDADB_MIGRATION_RUN_PINECONE_REAL_E2E=0

# LambdaDB target connection.
LAMBDADB_BASE_URL="your-region-specific-lambdadb-base-url"
LAMBDADB_PROJECT_NAME="your-lambdadb-project-name"
LAMBDADB_PROJECT_API_KEY="your-project-api-key"

# Qdrant source settings.
LAMBDADB_MIGRATION_QDRANT_URL="http://localhost:6334"
LAMBDADB_MIGRATION_QDRANT_REAL_LARGE_COUNT=64

# Pinecone source settings.
# PINECONE_API_KEY is also read by the official Pinecone Go SDK.
PINECONE_API_KEY="your-pinecone-api-key"
LAMBDADB_MIGRATION_PINECONE_CLOUD="aws"
LAMBDADB_MIGRATION_PINECONE_REGION="us-east-1"
LAMBDADB_MIGRATION_PINECONE_NAMESPACE=""
